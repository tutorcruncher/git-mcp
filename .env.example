# ─── Auth ─────────────────────────────────────────────────────────────────────
# OAuth and key-based auth are independent and can be enabled together:
#   • GitHub OAuth — set the OAuth App credentials block below (+ an org gate).
#     Best for interactive clients (Claude Desktop / claude.ai); each user acts as
#     themselves via their own GitHub token.
#   • Key-based — set MCP_API_KEYS below. Best for a headless app/agent; clients
#     send `Authorization: Bearer <key>` and act as the GITHUB_BACKEND_TOKEN PAT.
#   • Both — set both blocks. The server serves OAuth AND accepts the static keys,
#     so an OAuth client and a headless key client can use the same deployment.
# At least one of (OAuth credentials) / (MCP_API_KEYS) must be set or the server
# refuses to start.

# ─── Key-based auth (for connecting a headless client / agent) ─────────────────
# Comma- or space-separated static API keys. Clients send `Authorization: Bearer <key>`.
# Generate strong random values (e.g. `openssl rand -hex 32`). A valid key is its own
# gate (no org membership check), so treat keys as secrets. Leave empty to disable.
MCP_API_KEYS=

# Static GitHub token (PAT) the proxy forwards to the backend github-mcp-server for
# key-authenticated requests (there is no per-user OAuth token then). REQUIRED when
# MCP_API_KEYS is set. This token determines what GitHub the proxied tools can see —
# use a classic or fine-grained PAT with the access the tools need (e.g. repo /
# read:org). Not used for OAuth requests (the connecting user's token is used instead).
GITHUB_BACKEND_TOKEN=

# ─── Auth (GitHub OAuth) — set these to serve the OAuth flow ───────────────────
# GitHub OAuth App credentials (Settings → Developer settings → OAuth Apps)
GITHUB_OAUTH_CLIENT_ID=Ov23li_xxxxxxxxxxxx
GITHUB_OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public HTTPS base URL of THIS server. Must match the OAuth App callback:
#   <BASE_URL>/auth/callback
BASE_URL=https://your-app.herokuapp.com

# GitHub scopes the proxied tools need (space-separated).
GITHUB_SCOPES=repo read:org read:user

# Backend github-mcp-server (http mode) URL. Local-only; spawned as a subprocess.
BACKEND_MCP_URL=http://127.0.0.1:8082/mcp

# Toolsets exposed by the backend (comma-separated, or "all"). Sent per request.
GITHUB_TOOLSETS=repos,issues,pull_requests,users,context

# Set to 1 to force read-only tools.
READ_ONLY=0

# Restrict OAuth users to active members of this GitHub org. Strongly recommended.
# Applies to OAuth requests only; key-authenticated requests bypass it.
ALLOWED_GITHUB_ORG=your-org

# When OAuth is enabled, the server refuses to start without ALLOWED_GITHUB_ORG
# unless this is 1. Set to 1 ONLY to deliberately allow any authenticated GitHub user.
ALLOW_UNGATED=0

# Space-separated OAuth client redirect URIs permitted during registration.
ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback

# Signing key for the FastMCP-issued JWTs (generate a strong random value in prod).
JWT_SIGNING_KEY=change-me-in-production

# Redis URL for persisting OAuth state (client registrations + tokens) across
# restarts. Required on hosts with an ephemeral filesystem (e.g. Heroku, where
# daily dyno cycling otherwise wipes the on-disk store and expires every
# connection). On Heroku the Key-Value Store add-on sets this to a rediss:// URL
# automatically. Leave unset for local dev to use the default on-disk store.
REDIS_URL=

# Port the MCP server binds to. Heroku sets this automatically.
PORT=8000

# Path to the github-mcp-server binary inside the container/dyno.
GITHUB_MCP_BINARY=github-mcp-server

# ─── Observability (optional) ─────────────────────────────────────────────────
# Pydantic Logfire write token. When set, the server traces httpx upstream calls
# (backend github-mcp-server / GitHub API) and a span per tool call. Unset = fully
# disabled (no data leaves the app).
LOGFIRE_TOKEN=
